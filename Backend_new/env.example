# ─── LocalCart Backend Environment Variables ───────────────────
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local MongoDB (default):
MONGO_URI=mongodb://127.0.0.1:27017/localcart

# MongoDB Atlas (cloud) example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/localcart?retryWrites=true&w=majority

# Port the server runs on
PORT=5000
